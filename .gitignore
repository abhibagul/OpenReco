# OpenReco
# per-project cache + run history (content-addressed, regenerable)
.openreco/
# sample imagery is fetched via scripts/fetch_sample.py, not committed
samples/*/images/
# input imagery / datasets (keep project.toml manifests, not the raw images)
*.JPG
*.jpg
*.jpeg
*.png
*.tif
*.tiff
# generated shareable bundles (any project)
**/output/
# machine-generated GCP files derived from user data
aerialdata/gcps.csv
# but DO keep the viewer's own template assets if any are added later
!openreco/viewer/template/**

# local end-to-end validation scratch (not part of the package)
valproj/
valproj_run.py
valproj_run.log
verify_transforms.py
# wheel-build verification scratch
dist_check/
_whlvenv/
_whltest/

# Python
*.egg-info/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
build/
dist/
# PyInstaller frozen-binary build scratch
*.spec.bak
.venv/
venv/
tools/
